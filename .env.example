# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Groq AI - Main AI Provider
GROQ_API_KEY=your_groq_api_key

# RAG Search (Serper.dev - 2500 free requests/month)
# Get key at: https://serper.dev
SERPER_API_KEY=your_serper_api_key

# HuggingFace (optional - for better embeddings)
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key

# DeepSeek (optional - cheap for heavy tasks)
DEEPSEEK_API_KEY=your_deepseek_api_key

# AI Agent (multi-step generation)
USE_AI_AGENT=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Pipedream Automation (Telegram notifications)
PIPEDREAM_WEBHOOK_URL=https://your-pipedream-webhook-url
PIPEDREAM_AUTH_KEY=your-secret-auth-key

# Cron Jobs Security
CRON_SECRET=your-cron-secret-key

# MCP (Model Context Protocol) Integration
# Enable MCP servers for extended AI capabilities
MCP_ENABLED=true

# Brave Search API (for web search functionality)
# Get your API key at: https://brave.com/search/api/
# Free tier: 2000 queries/month
BRAVE_API_KEY=your_brave_api_key

# MCP Filesystem Path (for user file storage)
# Default: ./user-files
MCP_FILESYSTEM_PATH=./user-files

# MADI Schedule Parser
# Enable real-time schedule parsing from MADI website (Requirements: 7.1, 7.2)
# Set to 'true' to enable parser, 'false' to use static data only
USE_MADI_PARSER=false

# Cache TTL in seconds (default: 3600 = 1 hour) (Requirements: 7.3)
# How long to keep parsed schedule data in cache before refreshing
MADI_CACHE_TTL=3600

# Request timeout in milliseconds (default: 10000 = 10 seconds) (Requirements: 7.4)
# Maximum time to wait for MADI website response
MADI_REQUEST_TIMEOUT=10000

# Fallback to static data on parser failure (default: true) (Requirements: 7.5)
# If 'true', uses static schedule data when parser fails
MADI_FALLBACK_TO_STATIC=true

# MADI website base URL (default: https://www.madi.ru/tplan)
MADI_BASE_URL=https://www.madi.ru/tplan
